   "source": [
    "# This program prints skills with numbering and total count.\n",
    "\n",
    "skills = [\"Python\", \"C++\", \"SQL\", \"GitHub\", \"Problem Solving\" , \"DSA\"]\n",
    "\n",
    "for index, skill in enumerate(skills, start=1):\n",
    "    print(f\"{index}. {skill}\")\n",
    "\n",
    "print(f\"\\nTotal Skills: {len(skills)}\")"
   ]
